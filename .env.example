# Copy this file to ".env" (without the .example) and adjust values.
#
# Recipient for contact form emails
CONTACT_TO=email@christina-busacker.de

# Default sender address/name (used for mail() and SMTP)
MAIL_FROM_EMAIL=website@christina-busacker.de
MAIL_FROM_NAME="christina-busacker.de"

# SMTP (optional). If SMTP_HOST is set, the contact form will use SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# tls | ssl | none
SMTP_SECURE=tls
